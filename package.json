{
  "name": "barstock",
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "clean": "turbo clean",
    "db:generate": "pnpm --filter @barstock/database generate",
    "db:push": "pnpm --filter @barstock/database push",
    "db:studio": "pnpm --filter @barstock/database studio",
    "db:seed": "pnpm --filter @barstock/database seed",
    "android": "expo run:android",
    "ios": "expo run:ios"
  },
  "devDependencies": {
    "turbo": "^2.8.13",
    "typescript": "^5.7.3"
  },
  "dependencies": {
    "expo-haptics": "~15.0.8",
    "expo": "~52.0.49",
    "react": "18.3.1",
    "react-native": "0.84.1"
  },
  "version": "1.0.0",
  "pnpm": {
    "overrides": {
      "tar": ">=7.5.7",
      "minimatch": ">=3.1.4 <10.0.0 || >=10.2.3"
    }
  }
}
